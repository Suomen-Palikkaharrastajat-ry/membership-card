{
  profiles.devcontainer.module = {
    devcontainer.enable = true;
    devcontainer.tweaks = [
      "gpg-agent"
      "podman"
      "vscode"
    ];
    devcontainer.settings.customizations.vscode.extensions = [
      "datakurre.devenv"
      "anthropic.claude-code"
      "elmTooling.elm-ls-vscode"
      "GitHub.copilot"
      "GitHub.copilot-chat"
      "jnoortheen.nix-ide"
      "vscodevim.vim"
    ];
  };
}
